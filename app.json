{
  "expo": {
    "name": "MUST Connect",
    "slug": "must-connect-",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050b14",
    "primaryColor": "#E8A020",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050b14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ke.ac.must.connect",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "MUST Connect needs camera access to take profile photos.",
        "NSPhotoLibraryUsageDescription": "MUST Connect needs photo library access to upload images.",
        "NSPhotoLibraryAddUsageDescription": "MUST Connect needs to save photos.",
        "NSMicrophoneUsageDescription": "MUST Connect needs microphone for voice messages.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2B6B"
      },
      "package": "ke.ac.must.connect",
      "versionCode": 1,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#050b14",
        "translucent": false
      },
      "navigationBar": {
        "barStyle": "dark",
        "backgroundColor": "#050b14"
      },
      "allowBackup": false,
      "blockedPermissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050b14",
          "image": "./assets/splash.png",
          "imageWidth": 380
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MUST Connect needs access to your photos to set a profile picture."
        }
      ],
      "expo-navigation-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "32ceb9c4-d660-4397-a371-b9b18b8cd25a"
      }
    },
    "owner": "bd_mutant7"
  }
}
